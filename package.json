  "scripts": {
    "validate": "bash validators/check-refs.sh && node validators/check-a11y-basics.js examples/ && node validators/check-a11y-basics.js website/ && node validators/check-drift.js examples/ && node validators/check-drift.js website/",
    "test": "node validators/test-cli.js && node validators/check-modules.js",
    "check:links": "node validators/check-links.js --fast",
    "review": "node bin/designos.js review",
    "visual": "node bin/designos.js visual",
    "starter": "node bin/designos.js starter",
    "brief": "node bin/designos.js brief",
    "demo:terminal": "node scripts/demo-session.js",
    "demo:transcript": "bash scripts/record-demo.sh",
    "demo:gif": "python3 scripts/render-demo-gif.py",
    "doctor": "node bin/designos.js doctor",
