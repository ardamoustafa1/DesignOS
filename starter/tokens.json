{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "DesignOS starter tokens — W3C Design Tokens format twin of tokens.css. Semantic (Tier 2) layer only; see foundations/design-tokens.md for the architecture.",
  "color": {
    "bg": {
      "page":           { "$type": "color", "$value": "#ffffff", "$extensions": { "designos.dark": "#0a0a0b" } },
      "surface":        { "$type": "color", "$value": "#fafafa", "$extensions": { "designos.dark": "#131316" } },
      "surface-raised": { "$type": "color", "$value": "#ffffff", "$extensions": { "designos.dark": "#1c1c21" } },
      "inverse":        { "$type": "color", "$value": "#18181b", "$extensions": { "designos.dark": "#fafafa" } }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "#18181b", "$extensions": { "designos.dark": "#fafafa" } },
      "secondary": { "$type": "color", "$value": "#3f3f46", "$extensions": { "designos.dark": "#d4d4d8" } },
      "muted":     { "$type": "color", "$value": "#71717a", "$extensions": { "designos.dark": "#9d9da6" } },
      "on-accent": { "$type": "color", "$value": "#ffffff", "$extensions": { "designos.dark": "#101018" } }
    },
    "border": {
      "default": { "$type": "color", "$value": "#e4e4e7", "$extensions": { "designos.dark": "rgb(255 255 255 / 0.08)" } },
      "strong":  { "$type": "color", "$value": "#a1a1aa", "$extensions": { "designos.dark": "rgb(255 255 255 / 0.16)" } },
      "focus":   { "$type": "color", "$value": "{color.accent.default}" }
    },
    "accent": {
      "default": { "$type": "color", "$value": "#4f46e5", "$extensions": { "designos.dark": "#818cf8" } },
      "hover":   { "$type": "color", "$value": "#4338ca", "$extensions": { "designos.dark": "#a5b4fc" } },
      "subtle":  { "$type": "color", "$value": "#eef2ff", "$extensions": { "designos.dark": "rgb(129 140 248 / 0.12)" } }
    },
    "semantic": {
      "success": { "$type": "color", "$value": "#16a34a", "$extensions": { "designos.dark": "#4ade80" } },
      "warning": { "$type": "color", "$value": "#d97706", "$extensions": { "designos.dark": "#fbbf24" } },
      "danger":  { "$type": "color", "$value": "#dc2626", "$extensions": { "designos.dark": "#f87171" } },
      "info":    { "$type": "color", "$value": "#0284c7", "$extensions": { "designos.dark": "#38bdf8" } }
    }
  },
  "dimension": {
    "space": {
      "1": { "$type": "dimension", "$value": "4px" },  "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" }, "4": { "$type": "dimension", "$value": "16px" },
      "6": { "$type": "dimension", "$value": "24px" }, "8": { "$type": "dimension", "$value": "32px" },
      "12": { "$type": "dimension", "$value": "48px" }, "16": { "$type": "dimension", "$value": "64px" },
      "24": { "$type": "dimension", "$value": "96px" }, "32": { "$type": "dimension", "$value": "128px" }
    },
    "radius": {
      "sm": { "$type": "dimension", "$value": "6px" },
      "md": { "$type": "dimension", "$value": "10px" },
      "lg": { "$type": "dimension", "$value": "16px" },
      "full": { "$type": "dimension", "$value": "9999px" }
    },
    "container": {
      "prose":     { "$type": "dimension", "$value": "700px" },
      "marketing": { "$type": "dimension", "$value": "1180px" },
      "wide":      { "$type": "dimension", "$value": "1360px" }
    }
  },
  "fontFamily": {
    "sans": { "$type": "fontFamily", "$value": ["Inter", "ui-sans-serif", "system-ui", "sans-serif"] },
    "mono": { "$type": "fontFamily", "$value": ["Geist Mono", "ui-monospace", "SF Mono", "monospace"] }
  },
  "duration": {
    "instant": { "$type": "duration", "$value": "100ms" },
    "fast":    { "$type": "duration", "$value": "150ms" },
    "base":    { "$type": "duration", "$value": "200ms" },
    "slow":    { "$type": "duration", "$value": "300ms" },
    "slower":  { "$type": "duration", "$value": "500ms" }
  },
  "cubicBezier": {
    "ease-out":    { "$type": "cubicBezier", "$value": [0.16, 1, 0.3, 1] },
    "ease-in-out": { "$type": "cubicBezier", "$value": [0.65, 0, 0.35, 1] }
  }
}
